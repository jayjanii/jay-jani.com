---
import Layout from '../layouts/Layout.astro';
import pfp from '../assets/pfp.png';
---

<Layout title="Jay Jani">
  
  <div class="relative max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    
    <!-- Top Nav: absolute so it does not shift the main column -->
    <nav class="absolute top-12 right-4 sm:right-6 lg:right-8 z-10 flex flex-col items-end" aria-label="Site">
      <button
        id="admin-login-pill"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium border border-red-500/50 bg-red-600/25 text-red-300 shadow-sm hover:bg-red-600/35 hover:border-red-400 hover:text-white transition-colors cursor-pointer mb-[62px]"
        style="display:none"
      >
        <svg class="w-3.5 h-3.5 shrink-0 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        Admin
      </button>
      <a
        id="admin-enter-pill"
        href="/projects/admin"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium border border-blue-500/50 bg-blue-600/25 text-blue-300 shadow-sm hover:bg-blue-600/35 hover:border-blue-400 hover:text-white transition-colors mb-2"
        style="display:none"
      >
        <svg class="w-3.5 h-3.5 shrink-0 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Dashboard
      </a>
      <button
        id="admin-logout-pill"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium border border-red-500/50 bg-red-600/25 text-red-300 shadow-sm hover:bg-red-600/35 hover:border-red-400 hover:text-white transition-colors cursor-pointer mb-[62px]"
        style="display:none"
      >
        <svg class="w-3.5 h-3.5 shrink-0 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Log Out
      </button>
      <a
        href="/reading"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium border border-blue-500/50 bg-blue-600/25 text-blue-300 shadow-sm hover:bg-blue-600/35 hover:border-blue-400 hover:text-white transition-colors mb-2"
      >
        <svg class="w-3.5 h-3.5 shrink-0 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        Reading List
      </a>
      <a
        href="/climbing"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium border border-blue-500/50 bg-blue-600/25 text-blue-300 shadow-sm hover:bg-blue-600/35 hover:border-blue-400 hover:text-white transition-colors"
      >
        <svg class="w-3.5 h-3.5 shrink-0 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Climbing Log
      </a>
    </nav>

    <!-- Auth gate modal -->
    <div id="auth-gate" class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 flex items-center justify-center hidden">
      <div class="bg-gray-900 border border-gray-700 rounded-xl p-8 max-w-sm w-full mx-4">
        <h2 class="text-lg font-bold text-white mb-1">Admin Access</h2>
        <p class="text-gray-500 text-xs mb-5">Enter the admin password to continue.</p>
        <input type="password" id="auth-password" placeholder="Password" class="w-full bg-gray-800 border border-gray-700 rounded px-4 py-2 text-white text-sm mb-3 focus:border-blue-500 outline-none" />
        <p id="auth-error" class="text-red-400 text-xs mb-3 hidden">Incorrect password. Try again.</p>
        <div class="flex gap-3">
          <button id="auth-submit" class="flex-1 px-4 py-2 bg-blue-600 text-white font-bold rounded hover:bg-blue-500 transition-colors text-sm">Enter</button>
          <button id="auth-cancel" class="px-4 py-2 bg-gray-800 text-gray-400 rounded hover:bg-gray-700 transition-colors text-sm">Cancel</button>
        </div>
      </div>
    </div>

    <!-- Profile Section -->
    <section class="flex flex-col md:flex-row items-center md:items-start gap-8 mb-16">
      <div class="w-32 h-32 rounded-full shrink-0 border border-gray-700 shadow-lg overflow-hidden">
        <img src={pfp.src} alt="Jay Jani" class="w-full h-full object-cover" />
      </div>
      <div class="text-center md:text-left">
        <h1 class="text-4xl font-bold text-white tracking-tight mb-2">Jay Jani</h1>
        <p class="text-xl text-gray-400 mb-4">Aspiring AI/ML Engineer</p>
        <div class="flex items-center justify-center md:justify-start gap-2 text-gray-500 mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
          <span>Computer Science @ UCSC</span>
        </div>
        <div class="flex flex-col items-center md:items-start gap-1 mb-4">
          <button data-copy="contact@jay-jani.com" class="copy-email text-blue-400 hover:text-blue-300 transition-colors text-sm cursor-pointer">contact@jay-jani.com</button>
          <button data-copy="jdjani@ucsc.edu" class="copy-email text-blue-400 hover:text-blue-300 transition-colors text-sm cursor-pointer">jdjani@ucsc.edu</button>
        </div>
        <div class="flex items-center justify-center md:justify-start gap-4">
          <a href="https://github.com/jayjanii" target="_blank" class="text-blue-400 hover:text-blue-300 hover:underline transition-colors">GitHub</a>
        </div>
      </div>
    </section>

    <hr class="border-gray-800 my-12" />

    <!-- Projects Section -->
    <section>
      <h2 class="text-2xl font-bold mb-8 text-white">Projects</h2>
      <div id="project-list" class="space-y-12"></div>
      <div id="project-empty" class="text-center py-8 hidden">
        <p class="text-gray-600 text-sm">No projects yet.</p>
      </div>
    </section>

  </div>

  <!-- Copy toast -->
  <div id="copy-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-gray-800 border border-gray-700 text-gray-200 text-xs font-mono px-4 py-2 rounded-full shadow-lg opacity-0 pointer-events-none transition-opacity duration-300 z-50">
    Copied to clipboard
  </div>
</Layout>

<script>
  import { verifyPassword } from '../lib/climbing';
  import { renderRichText } from '../lib/richText';
  import { fetchProjects } from '../lib/projects';

  let toastTimer: ReturnType<typeof setTimeout> | null = null;
  let homePageAbort: AbortController | null = null;

  function isHomePath() {
    const p = location.pathname.replace(/\/$/, '') || '/';
    return p === '/';
  }

  const eyeSvg = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>';
  const ghSvg = '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>';
  const lockSvg = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>';

  function updatePillState() {
    const loginPill = document.getElementById('admin-login-pill') as HTMLButtonElement | null;
    const enterPill = document.getElementById('admin-enter-pill') as HTMLAnchorElement | null;
    const logoutPill = document.getElementById('admin-logout-pill') as HTMLButtonElement | null;
    if (!loginPill || !enterPill || !logoutPill) return;
    const loggedIn = !!localStorage.getItem('admin-token');
    loginPill.style.display = loggedIn ? 'none' : 'inline-flex';
    enterPill.style.display = loggedIn ? 'inline-flex' : 'none';
    logoutPill.style.display = loggedIn ? 'inline-flex' : 'none';
  }

  async function loadProjects() {
    const projectListEl = document.getElementById('project-list') as HTMLDivElement | null;
    const projectEmpty = document.getElementById('project-empty') as HTMLDivElement | null;
    if (!projectListEl || !projectEmpty) return;

    const projects = await fetchProjects();
    projectEmpty.style.display = projects.length === 0 ? 'block' : 'none';
    projectListEl.innerHTML = '';

    for (const p of projects) {
      const links: string[] = [];

      if (p.demo_url) {
        const isExternal = p.demo_url.startsWith('http');
        links.push(`<a href="${p.demo_url}"${isExternal ? ' target="_blank"' : ''} class="inline-flex items-center gap-1 text-blue-400 hover:text-blue-300 hover:underline">${eyeSvg}${p.demo_label || p.demo_url}</a>`);
      }

      if (p.is_private) {
        links.push(`<span class="inline-flex items-center gap-1 text-gray-500 cursor-default select-none">${lockSvg}Source not public</span>`);
      } else if (p.github_url) {
        links.push(`<a href="${p.github_url}" target="_blank" class="inline-flex items-center gap-1 text-gray-400 hover:text-gray-300 hover:underline">${ghSvg}GitHub Source</a>`);
      }

      const article = document.createElement('article');
      article.className = 'group relative bg-gray-900/40 border border-gray-800 rounded-xl p-6 hover:bg-gray-900/60 transition-colors';
      article.innerHTML = `
        <h3 class="text-xl font-bold mb-3 text-white">${p.title}</h3>
        ${p.description ? `<div class="rich-text text-gray-400 leading-relaxed mb-4 text-sm">${renderRichText(p.description)}</div>` : ''}
        ${links.length ? `<div class="flex gap-4 text-sm">${links.join('')}</div>` : ''}
      `;
      projectListEl.appendChild(article);
    }
  }

  function initHomePage() {
    homePageAbort = new AbortController();
    const { signal } = homePageAbort;

    document.querySelectorAll<HTMLButtonElement>('.copy-email').forEach((btn) => {
      btn.addEventListener(
        'click',
        () => {
          const email = btn.dataset.copy ?? '';
          navigator.clipboard.writeText(email).then(() => {
            const toast = document.getElementById('copy-toast');
            if (!toast) return;
            toast.textContent = `Copied ${email}`;
            toast.classList.remove('opacity-0');
            toast.classList.add('opacity-100');
            if (toastTimer) clearTimeout(toastTimer);
            toastTimer = setTimeout(() => {
              toast.classList.remove('opacity-100');
              toast.classList.add('opacity-0');
            }, 2000);
          });
        },
        { signal },
      );
    });

    const loginPill = document.getElementById('admin-login-pill') as HTMLButtonElement | null;
    const enterPill = document.getElementById('admin-enter-pill') as HTMLAnchorElement | null;
    const logoutPill = document.getElementById('admin-logout-pill') as HTMLButtonElement | null;
    const gate = document.getElementById('auth-gate') as HTMLDivElement | null;
    const authPw = document.getElementById('auth-password') as HTMLInputElement | null;
    const authErr = document.getElementById('auth-error') as HTMLParagraphElement | null;
    const authBtn = document.getElementById('auth-submit') as HTMLButtonElement | null;
    const cancelBtn = document.getElementById('auth-cancel') as HTMLButtonElement | null;

    if (!loginPill || !enterPill || !logoutPill || !gate || !authPw || !authErr || !authBtn || !cancelBtn) {
      return;
    }

    async function tryAuth() {
      const pw = authPw!.value;
      if (!pw) return;
      authBtn!.disabled = true;
      authBtn!.textContent = 'Checking...';

      try {
        const ok = await verifyPassword(pw);
        if (ok) {
          localStorage.setItem('admin-token', pw);
          gate!.classList.add('hidden');
          updatePillState();
        } else {
          authErr!.classList.remove('hidden');
          authPw!.value = '';
        }
      } catch {
        authErr!.classList.remove('hidden');
        authPw!.value = '';
      }
      authBtn!.disabled = false;
      authBtn!.textContent = 'Enter';
    }

    loginPill.addEventListener(
      'click',
      () => {
        authErr.classList.add('hidden');
        authPw.value = '';
        gate.classList.remove('hidden');
        authPw.focus();
      },
      { signal },
    );

    logoutPill.addEventListener(
      'click',
      () => {
        localStorage.removeItem('admin-token');
        updatePillState();
      },
      { signal },
    );

    authBtn.addEventListener('click', tryAuth, { signal });
    authPw.addEventListener('keydown', (e) => { if (e.key === 'Enter') tryAuth(); }, { signal });
    cancelBtn.addEventListener('click', () => gate.classList.add('hidden'), { signal });
    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape' && !gate.classList.contains('hidden')) gate.classList.add('hidden');
      },
      { signal },
    );

    updatePillState();
    loadProjects();
  }

  document.addEventListener('astro:page-load', () => {
    homePageAbort?.abort();
    homePageAbort = null;
    if (isHomePath()) initHomePage();
  });
</script>